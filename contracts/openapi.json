  "components": {
    "schemas": {
      "ApiErrorResponse": {
        "properties": {
          "error_code": {
            "type": "string",
            "title": "Error Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "error_code",
          "message"
        ],
        "title": "ApiErrorResponse"
      },
      "ApiValidationErrorResponse": {
        "properties": {
          "error_code": {
            "type": "string",
            "title": "Error Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "preview": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DrawImportPreviewResponse"
              },
              {
                "type": "null"
              }
