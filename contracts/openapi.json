          "is_valid",
          "content_sha256",
          "parser_version",
          "supported_lottery_types",
          "total_rows",
          "valid_rows",
          "blank_rows",
          "duplicate_rows",
          "conflict_rows_inside_input",
          "validation_error_count",
          "ignored_columns",
          "normalized_preview",
          "validation_errors",
          "preview_truncated",
          "errors_truncated"
