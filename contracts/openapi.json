        },
        "type": "object",
        "required": [
          "error_code",
          "message"
        ],
        "title": "ApiValidationErrorResponse"
      },
      "CommitConflictResponse": {
        "properties": {
          "error_code": {
            "type": "string",
            "title": "Error Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ImportCommitResultView"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "error_code",
          "message",
          "result"
        ],
        "title": "CommitConflictResponse"
      },
      "ConflictPolicy": {
        "type": "string",
        "enum": [
          "REJECT"
        ],
        "title": "ConflictPolicy",
        "description": "Import collision behavior supported by the current release."
      },
      "DrawHistoryResponse": {
        "properties": {
          "records": {
            "items": {
              "$ref": "#/components/schemas/DrawRecordView"
            },
            "type": "array",
            "title": "Records"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "page_size": {
            "type": "integer",
            "title": "Page Size"
          },
          "total_count": {
            "type": "integer",
            "title": "Total Count"
          },
          "total_pages": {
            "type": "integer",
            "title": "Total Pages"
          },
          "sort": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sort"
          }
        },
        "type": "object",
        "required": [
          "records",
          "page",
          "page_size",
          "total_count",
          "total_pages",
          "sort"
        ],
        "title": "DrawHistoryResponse"
      },
      "DrawImportCommitRequest": {
        "properties": {
          "filename": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Filename"
          },
          "csv_text": {
            "type": "string",
            "title": "Csv Text"
          },
          "expected_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "title": "Expected Sha256"
          },
          "parser_version": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Parser Version"
          },
          "conflict_policy": {
            "$ref": "#/components/schemas/ConflictPolicy"
          }
