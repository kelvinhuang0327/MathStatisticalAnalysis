        "additionalProperties": false,
        "type": "object",
        "required": [
          "filename",
          "csv_text",
          "expected_sha256",
          "parser_version",
          "conflict_policy"
        ],
        "title": "DrawImportCommitRequest"
      },
      "DrawImportErrorView": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "row_number": {
            "anyOf": [
