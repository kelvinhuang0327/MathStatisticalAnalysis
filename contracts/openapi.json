{
  "openapi": "3.1.0",
  "info": {
    "title": "LottoLab API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Api Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/strategies": {
      "get": {
        "summary": "Strategies",
        "operationId": "strategies_api_strategies_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/StrategyView"
                  },
                  "type": "array",
                  "title": "Response Strategies Api Strategies Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StrategyView": {
        "properties": {
          "strategy_id": {
            "type": "string",
            "title": "Strategy Id"
          },
          "strategy_name": {
            "type": "string",
            "title": "Strategy Name"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "lottery_types": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Lottery Types"
          },
          "lifecycle_status": {
            "type": "string",
            "title": "Lifecycle Status"
          },
          "executable": {
            "type": "boolean",
            "title": "Executable"
          }
        },
        "type": "object",
        "required": [
          "strategy_id",
          "strategy_name",
          "version",
          "lottery_types",
          "lifecycle_status",
          "executable"
        ],
        "title": "StrategyView"
      }
    }
  }
}
